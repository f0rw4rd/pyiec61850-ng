# Ignore the libiec61850 directory (source code downloaded by build script)
/libiec61850/

# Ignore compiled Python files
*.pyc
__pycache__/
*.py[cod]
*$py.class

# SWIG-generated Python wrapper (produced at build time)
pyiec61850/pyiec61850.py

# auditwheel-relocated native lib dir (dropped in from a built wheel for local testing)
*.libs/

# Ignore build directories
/build/
/dist/
/lib/libiec61850/
*.so
*.dll
*.dylib

dist/*


# Ignore virtualenvs
.venv/
venv/

# Test / coverage artifacts
.coverage
.coverage.*
htmlcov/
.pytest_cache/

# Ignore IDE files
.idea/
.vscode/
*.swp
*.swo

# Ignore temporary files
.DS_Store
*~

